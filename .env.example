# ── AgentCost — Environment Variables ──────────────────────

# Required: At least one LLM provider key
OPENAI_API_KEY=sk-...

# Optional: For benchmarking Anthropic models directly
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LiteLLM Proxy configuration (for virtual keys)
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_API_KEY=sk-virtual-key-...

# Optional: Provider keys when using LiteLLM SDK mode
# GROQ_API_KEY=gsk-...
# TOGETHERAI_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...

# Optional: Override defaults
# AGENTCOST_DB=~/.agentcost/benchmarks.db
# AGENTCOST_TASKS=./sample-data/tasks.jsonl

# PostgreSQL (for migrations when using Postgres)
# AGENTCOST_DATABASE_URL=postgresql://postgres@localhost:5432/agentcost

# ACP Server (only needed if running the execution server)
# ACP_PORT=8080
# ACP_HOST=127.0.0.1
