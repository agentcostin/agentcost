+function simTick(state){
+  const fx=new Set();state.activeEvents.forEach(e=>{if(e.fx)fx.add(e.fx);});
+  const tr=state.config.traffic,base=tr*22;
+  let rm=1;if(fx.has('outage'))rm=.08;else if(fx.has('ratelimit'))rm=.35;else if(fx.has('partial_down'))rm=.5;
