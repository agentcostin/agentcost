+  const llmR=rps*(1-chr);
+  let tpr=850;if(fx.has('runaway'))tpr*=5;if(fx.has('runaway_cascade'))tpr*=20;if(fx.has('context_overflow'))tpr*=2;
+  if(fx.has('retry_storm'))tpr*=4;if(fx.has('prompt_compress'))tpr*=.7;
+  let cm=1;if(fx.has('cost_2x'))cm=2;if(fx.has('cost_3x'))cm=3;if(fx.has('cost_5x'))cm=5;
+  const cps=(llmR*tpr*.0000025*cm)+(llmR*tpr*.4*.00001*cm);
+  let lat=14+tr*.6;if(fx.has('outage'))lat=9500;else if(fx.has('ratelimit'))lat=2400;
+  else if(fx.has('cachemiss'))lat=520;else if(fx.has('latency_10x'))lat*=10;
+  lat=Math.max(1,lat+(Math.random()-.5)*10);
+  let avl=99.9;if(fx.has('outage'))avl=fx.has('fallback_ok')?85:11.2;
+  else if(fx.has('ratelimit'))avl=64.8;else if(fx.has('budget_hard'))avl=0;
+  avl=Math.max(0,Math.min(100,avl-fx.size*.25));
+  const ld={};SIM_NODES.forEach(n=>{let b=state.loads[n.id]||20;b+=(Math.random()-.4)*18;
+    if(n.id==='llm'&&fx.has('outage'))b=0;if(n.id==='ch'&&fx.has('cachemiss'))b=95;
+    if(n.id==='ag'&&fx.has('runaway'))b=98;ld[n.id]=Math.max(0,Math.min(100,b));});
+  const m={rps,lat,avl,cph:Math.max(0,cps*3600),spent:state.metrics.spent+Math.max(0,cps),
+    tok:state.metrics.tok+rps*1.6,budget:state.config.budget||5000,chr};
+  const risks=[];fx.forEach(f=>{if(RISK_MAP[f])risks.push({...RISK_MAP[f]});});
+  const bp=m.budget>0?m.spent/m.budget:0;
+  if(bp>=.95&&!fx.has('budget_hard'))risks.push({n:'db',l:'95% BUDGET',c:'#f87171'});
+  else if(bp>=.8&&!fx.has('budget_hard'))risks.push({n:'db',l:'80% BUDGET',c:'#fbbf24'});
+  return{...state,tick:state.tick+1,metrics:m,loads:ld,risks};
+}
